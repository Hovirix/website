---
interface Props {
	title: string;
	kicker?: string;
	asideText?: string;
	asideClass?: string;
}

const {
	title,
	kicker,
	asideText,
	asideClass = "hidden max-w-[24ch] text-right font-mono text-xs leading-relaxed text-muted-foreground sm:block",
} = Astro.props;
---

<div class="animate-fade-up border-b px-8 py-14">
  <div class="flex items-end justify-between gap-4">
    <div>
      {kicker && (
        <p class="mb-2 font-mono text-[10px] tracking-[0.25em] text-muted-foreground uppercase">
          {kicker}
        </p>
      )}
      <h1 class="text-5xl font-extrabold tracking-[-0.04em] text-foreground sm:text-6xl lg:text-7xl">
        {title}
      </h1>
    </div>
    {asideText && (
      <p class={asideClass}>
        {asideText}
      </p>
    )}
  </div>
</div>
