---
import type { CollectionEntry } from "astro:content";

interface Props {
  items: CollectionEntry<"research">[];
}

const { items } = Astro.props;
---

<section>
  {
    items.map((item) => {
      const researchSlug = item.id.replace(/\.(md|mdx)$/i, "");
      return (
      <article
        class="border-b border-outline-variant/10"
        data-research-item
        data-category={item.data.category.toLowerCase().replace(/\s+/g, "-")}
      >
        <a href={`/research/${researchSlug}`} class="group block py-12 transition-colors hover:bg-surface-container-lowest/40">
          <div class="flex flex-col gap-4 md:flex-row md:items-baseline md:gap-12">
            <div class="w-full flex-shrink-0 font-mono text-xs text-on-surface-variant md:w-32">{item.data.pubdate}</div>
            <div class="flex-grow">
              <div class="mb-3 flex flex-wrap gap-2">
                <span class="font-mono text-[10px] uppercase tracking-tight text-primary">{item.data.category}</span>
              </div>
              <h3 class="mb-3 inline-flex items-center gap-2 text-2xl font-semibold text-on-surface transition-all duration-200 group-hover:text-primary group-hover:translate-x-1">
                {item.data.title}
                <span
                  class="material-symbols-outlined text-lg opacity-0 -translate-x-1 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-0"
                  aria-hidden="true"
                >
                  arrow_outward
                </span>
              </h3>
              <p class="max-w-3xl text-sm text-on-surface-variant">{item.data.description}</p>
            </div>
          </div>
        </a>
      </article>
      );
    })
  }
</section>
