---
import Button from "../ui/Button.astro";
import SectionShell from "../ui/SectionShell.astro";
---

<SectionShell>
  <div class="ghost-border bg-surface-container-low p-10 md:p-14">
    <div class="grid gap-8 md:grid-cols-[minmax(0,1fr)_auto] md:items-center">
      <div class="max-w-2xl">
        <h2 class="mb-4 text-4xl font-bold tracking-tight md:text-5xl">Get in Touch</h2>
        <p class="text-base leading-relaxed text-on-surface-variant md:text-lg">
          Open to security, infrastructure, and research collaboration.
        </p>
      </div>
      <div class="self-start md:justify-self-end md:self-center">
        <Button href="/contact" variant="primary" class="min-w-40">Contact</Button>
      </div>
    </div>
  </div>
</SectionShell>
