---
import Icon from "../../ui/Icon.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  items: CollectionEntry<"projects">[];
}

const { items } = Astro.props;
---

<div
  class="project-grid grid grid-cols-1 border border-outline-variant/20 bg-outline-variant/20 md:grid-cols-2"
>
  {
    items.map((item) => {
      const projectSlug = item.id.replace(/\.(md|mdx)$/i, "");
      return (
        <article
          class="project-card group bg-[#151516] p-8 transition-all duration-500 hover:-translate-y-0.5 hover:bg-surface-container-high hover:shadow-[0_14px_36px_rgba(0,0,0,0.3)]"
          data-project-item
          data-category={item.data.category.toLowerCase()}
        >
          <div class="mb-6 flex items-start justify-between">
            <Icon
              name={item.data.icon}
              class="text-primary transition-transform group-hover:scale-110"
            />
            <span class="font-mono text-[10px] text-on-surface-variant/50">
              {item.data.pubdate}
            </span>
          </div>
          <h3 class="mb-3 text-xl font-bold tracking-tight transition-colors group-hover:text-primary">
            <a
              href={item.data.url ?? `/projects/${projectSlug}`}
              class="focus:outline-none focus-visible:ring-2 focus-visible:ring-primary"
            >
              {item.data.title}
            </a>
          </h3>
          <p class="mb-6 text-sm leading-relaxed text-on-surface-variant">
            {item.data.description}
          </p>
          <div class="mt-auto flex flex-wrap gap-2">
            {(item.data.tags ?? []).slice(0, 2).map((tag) => (
              <span class="bg-surface-container-highest px-2 py-0.5 font-mono text-[9px] text-on-surface-variant">
                {tag}
              </span>
            ))}
          </div>
        </article>
      );
    })
  }
</div>
