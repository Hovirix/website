---
import { ABOUT_SKILLS } from "@/lib/about";
import { cn } from "@/lib/utils";
---

<div class="animate-fade-up delay-100 border-b">
  <div class="border-b px-8 py-5">
    <span class="font-mono text-[11px] tracking-[0.25em] text-muted-foreground uppercase">
      Technical skills
    </span>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4">
    {ABOUT_SKILLS.map((group, i) => (
      <div class={cn("border-b p-8 sm:border-b-0", i < 3 && "md:border-r", i % 2 === 0 && "sm:border-r")}>
        <p class="mb-4 font-mono text-[10px] tracking-[0.25em] text-primary uppercase">
          {group.area}
        </p>
        <ul class="flex flex-col gap-2">
          {group.items.map((item) => (
            <li class="font-mono text-xs text-muted-foreground transition-colors hover:text-foreground">
              - {item}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</div>
