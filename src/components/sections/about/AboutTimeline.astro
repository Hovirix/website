---
import { ABOUT_TIMELINE } from "@/lib/about";
---

<div class="animate-fade-up delay-200 border-b">
  <div class="border-b px-8 py-5">
    <span class="font-mono text-[11px] tracking-[0.25em] text-muted-foreground uppercase">
      Experience
    </span>
  </div>
  <div>
    {ABOUT_TIMELINE.map((entry) => (
      <div class="group flex flex-col border-b last:border-b-0 transition-colors hover:bg-muted/20 md:flex-row md:items-stretch">
        <div class="relative flex shrink-0 items-center border-b px-8 py-5 md:w-40 md:border-r md:border-b-0 md:py-8">
          <span class="absolute left-0 top-0 h-full w-[3px] bg-primary opacity-0 transition-opacity group-hover:opacity-100" />
          <span class="font-mono text-sm font-bold text-foreground tabular-nums">
            {entry.year}
          </span>
        </div>
        <div class="flex flex-col justify-center gap-1 px-8 py-6 md:py-8">
          <p class="font-semibold tracking-tight text-foreground">
            {entry.role}
          </p>
          <p class="font-mono text-[11px] tracking-wider text-primary uppercase">
            {entry.org}
          </p>
          <p class="mt-1 text-sm leading-relaxed text-muted-foreground">
            {entry.note}
          </p>
        </div>
      </div>
    ))}
  </div>
</div>
