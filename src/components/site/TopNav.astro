---
import Button from "../ui/Button.astro";
import NavLinks from "./NavLinks.astro";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;
---

<nav class="fixed top-0 z-50 w-full border-b border-outline-variant/15 bg-background/95 backdrop-blur-sm">
  <div class="shell flex h-16 items-center justify-between">
    <a href="/" class="font-headline text-lg font-bold tracking-tight text-on-surface">Hovirix</a>
    <div class="flex items-center gap-3 md:gap-4">
      <div class="hidden items-center gap-5 md:flex">
        <NavLinks currentPath={currentPath} />
      </div>
      <Button
        href="/contact"
        variant="primary"
        class="hidden h-9 px-3.5 py-0 text-sm leading-none tracking-[0.08em] md:inline-flex"
      >
        Contact
      </Button>
      <button
        type="button"
        class="inline-flex h-9 w-9 items-center justify-center border border-outline-variant/30 text-on-surface transition-colors hover:border-primary hover:text-primary md:hidden"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav-panel"
        data-mobile-nav-toggle
      >
        <span class="sr-only">Menu</span>
        <span class="material-symbols-outlined text-xl" data-mobile-nav-icon>menu</span>
      </button>
    </div>
  </div>
</nav>

<div class="fixed inset-0 top-16 z-30 hidden bg-background/70 md:hidden" data-mobile-nav-backdrop></div>

<div
  id="mobile-nav-panel"
  class="fixed inset-x-0 top-16 z-40 hidden border-t border-outline-variant/15 bg-surface px-6 md:hidden"
  data-mobile-nav-panel
>
  <div class="shell space-y-2 px-0 py-5">
    <NavLinks currentPath={currentPath} variant="mobile" />
    <a
      href="/contact"
      class="mt-3 inline-flex h-9 items-center justify-center px-4 text-sm font-bold uppercase tracking-[0.1em] cta-machined text-on-primary"
      data-mobile-nav-link
    >
      Contact
    </a>
  </div>
</div>

<script>
  const toggle = document.querySelector("[data-mobile-nav-toggle]");
  const panel = document.querySelector("[data-mobile-nav-panel]");
  const backdrop = document.querySelector("[data-mobile-nav-backdrop]");
  const icon = document.querySelector("[data-mobile-nav-icon]");

  if (toggle instanceof HTMLButtonElement && panel instanceof HTMLElement && backdrop instanceof HTMLElement) {
    let isOpen = false;

    const sync = () => {
      panel.classList.toggle("hidden", !isOpen);
      backdrop.classList.toggle("hidden", !isOpen);
      document.body.classList.toggle("mobile-nav-open", isOpen);
      toggle.setAttribute("aria-expanded", String(isOpen));
      if (icon instanceof HTMLElement) {
        icon.textContent = isOpen ? "close" : "menu";
      }
    };

    const closeMenu = () => {
      isOpen = false;
      sync();
    };

    toggle.addEventListener("click", () => {
      isOpen = !isOpen;
      sync();
    });

    backdrop.addEventListener("click", closeMenu);

    panel.addEventListener("click", (event) => {
      const target = event.target;
      if (target instanceof HTMLElement && target.closest("a")) {
        closeMenu();
      }
    });

    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closeMenu();
      }
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 768) {
        closeMenu();
      }
    });
  }
</script>
