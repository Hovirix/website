---
interface Props {
	title: string;
	category: string;
	dateFormatted: string;
}

const { title, category, dateFormatted } = Astro.props;
---

<aside class="animate-fade-up delay-400 flex flex-col gap-0 border-t md:w-56 md:border-t-0">
  <div class="border-b px-6 py-8">
    <p class="mb-2 font-mono text-[10px] tracking-[0.25em] text-muted-foreground uppercase">Published</p>
    <p class="font-mono text-xs text-foreground">{dateFormatted}</p>
  </div>

  <div class="border-b px-6 py-8">
    <p class="mb-2 font-mono text-[10px] tracking-[0.25em] text-muted-foreground uppercase">Category</p>
    <p class="font-mono text-xs text-primary uppercase tracking-widest">{category}</p>
  </div>

  <div class="border-b px-6 py-8">
    <p class="mb-3 font-mono text-[10px] tracking-[0.25em] text-muted-foreground uppercase">Share</p>
    <div class="flex flex-col gap-2">
      <a
        href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="font-mono text-[11px] text-muted-foreground underline-offset-4 transition-colors hover:text-primary hover:underline"
      >
        Twitter / X →
      </a>
    </div>
  </div>

  <div class="mt-auto px-6 py-8">
    <a
      href="/blog"
      class="group inline-flex items-center gap-2 font-mono text-[11px] tracking-widest text-muted-foreground uppercase transition-colors hover:text-foreground"
    >
      <span class="transition-transform duration-200 group-hover:-translate-x-1">←</span>
      Back to blog
    </a>
  </div>
</aside>
