---
import type { CollectionEntry } from "astro:content";

interface Props {
	project: CollectionEntry<"projects">;
	index: number;
}

const { project, index } = Astro.props;
const indexLabel = String(index + 1).padStart(2, "0");
---

<a
  href={project.data.href}
  target="_blank"
  rel="noopener noreferrer"
  class="animate-fade-up group relative flex flex-col border-b last:border-b-0 no-underline transition-colors hover:bg-muted/20 md:flex-row md:items-stretch"
>
  <span
    class="pointer-events-none absolute right-2 top-1/2 -translate-y-1/2 select-none font-mono text-[7rem] font-extrabold leading-none text-foreground opacity-[0.03] transition-opacity duration-500 group-hover:opacity-[0.06] md:text-[9rem]"
    aria-hidden="true"
  >
    {indexLabel}
  </span>

  <div class="relative flex shrink-0 items-start gap-4 border-b px-8 py-6 md:w-56 md:flex-col md:justify-between md:border-b-0 md:border-r md:py-10">
    <span class="absolute left-0 top-0 h-full w-[3px] bg-primary opacity-0 transition-opacity group-hover:opacity-100" />
    <div>
      <span class="block font-mono text-[10px] tracking-[0.25em] text-muted-foreground uppercase">
        {indexLabel}
      </span>
      <span class="mt-1 block font-mono text-[11px] tracking-wider text-primary uppercase">
        {project.data.category}
      </span>
    </div>
    <span class="font-mono text-[11px] text-muted-foreground md:mt-auto">
      {project.data.year}
    </span>
  </div>

  <div class="relative flex flex-1 flex-col justify-center gap-3 px-8 py-8 md:py-10">
    <div class="flex items-start justify-between gap-4">
      <h2 class="text-xl font-bold leading-snug tracking-tight text-foreground transition-colors group-hover:text-primary md:text-2xl">
        {project.data.title}
      </h2>
      <span class="mt-1 shrink-0 translate-x-0 font-mono text-sm text-primary opacity-0 transition-all duration-300 group-hover:translate-x-1 group-hover:opacity-100">
        →
      </span>
    </div>
    <p class="max-w-xl text-sm leading-relaxed text-muted-foreground">
      {project.data.description}
    </p>
    <div class="flex flex-wrap gap-2 pt-1">
      {project.data.tags.map((tag) => (
        <span class="border border-border px-2 py-0.5 font-mono text-[10px] tracking-wider text-muted-foreground uppercase transition-colors group-hover:border-primary/30 group-hover:text-foreground">
          {tag}
        </span>
      ))}
    </div>
  </div>

  <div class="hidden w-44 shrink-0 overflow-hidden md:block">
    <img
      src={project.data.image}
      alt={project.data.title}
      class="h-full w-full object-cover opacity-0 grayscale transition-all duration-500 group-hover:scale-105 group-hover:opacity-50 group-hover:grayscale-0"
    />
  </div>
</a>
