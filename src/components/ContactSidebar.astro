---
import { CONTACT_EMAIL, GITHUB_URL } from "@/lib/site";
---

<div class="animate-fade-up delay-300 flex flex-col gap-0 md:w-64">
  <div class="relative border-b px-8 py-8">
    <span class="absolute left-0 top-0 h-full w-[3px] bg-primary" />
    <p class="mb-2 font-mono text-[10px] tracking-[0.25em] text-muted-foreground uppercase">Email</p>
    <a
      href={`mailto:${CONTACT_EMAIL}`}
      class="font-mono text-sm text-foreground underline-offset-4 transition-colors hover:text-primary hover:underline"
    >
      {CONTACT_EMAIL}
    </a>
  </div>

  <div class="border-b px-8 py-8">
    <p class="mb-2 font-mono text-[10px] tracking-[0.25em] text-muted-foreground uppercase">GitHub</p>
    <a
      href={GITHUB_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="font-mono text-sm text-foreground underline-offset-4 transition-colors hover:text-primary hover:underline"
    >
      {GITHUB_URL.replace("https://", "")}
    </a>
  </div>

  <div class="border-b px-8 py-8">
    <p class="mb-2 font-mono text-[10px] tracking-[0.25em] text-muted-foreground uppercase">Location</p>
    <p class="font-mono text-sm text-foreground">Remote · EU timezone</p>
  </div>

  <div class="border-b px-8 py-8">
    <p class="mb-3 font-mono text-[10px] tracking-[0.25em] text-muted-foreground uppercase">Response time</p>
    <p class="font-mono text-sm text-foreground">1–2 business days</p>
  </div>

  <div class="px-8 py-8">
    <p class="mb-3 font-mono text-[10px] tracking-[0.25em] text-muted-foreground uppercase">Availability</p>
    <div class="flex items-center gap-2.5">
      <span class="relative flex h-2 w-2 shrink-0">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary opacity-50"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-primary"></span>
      </span>
      <p class="font-mono text-sm text-foreground">Open to work</p>
    </div>
  </div>
</div>
