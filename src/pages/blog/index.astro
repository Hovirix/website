---
import { getCollection } from "astro:content";
import BlogGrid from "../../components/BlogGrid.tsx";
import Layout from "../../layouts/Layout.astro";

const allPosts = (await getCollection("blog"))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const [featured, ...rest] = allPosts;

const toPost = (p: (typeof allPosts)[number]) => ({
	id: p.id,
	title: p.data.title,
	description: p.data.description,
	pubDate: p.data.pubDate.toISOString(),
	category: p.data.category,
	image: p.data.image,
});
---

<Layout title="Blog">
  <div class="mx-auto max-w-6xl">

    <!-- Header -->
    <div class="animate-fade-up border-b px-8 py-16">
      <div class="flex items-end justify-between">
        <div>
          <span class="mb-4 block font-mono text-xs tracking-[0.25em] text-primary uppercase">
            — Writing
          </span>
          <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
            Blog
          </h1>
        </div>
        <span class="hidden font-mono text-xs text-muted-foreground sm:block">
          {allPosts.length} posts
        </span>
      </div>
    </div>

    <BlogGrid
      featured={toPost(featured)}
      posts={rest.map(toPost)}
      client:load
    />
  </div>
</Layout>
