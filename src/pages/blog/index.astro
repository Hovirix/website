---
import BlogGrid from "../../components/BlogGrid.tsx";
import PageHeader from "@/components/PageHeader.astro";
import PageShell from "@/components/PageShell.astro";
import Layout from "../../layouts/Layout.astro";
import { getPublishedBlogPosts } from "@/lib/content-queries";
import { toBlogCardViewModel } from "@/lib/view-models";

const allPosts = await getPublishedBlogPosts();

// Use explicitly flagged featured post, fall back to most recent.
const featured = allPosts.find((p) => p.data.featured) ?? allPosts[0];
const rest = featured ? allPosts.filter((p) => p.id !== featured.id) : [];

---

<Layout title="Blog">
  <PageShell path="sys://hovirix.dev/blog" meta={`${allPosts.length} posts`}>
    <PageHeader title="Writing" asideText="Homelab · Security / Productivity · Systems" />

    {featured ? (
      <BlogGrid
        featured={toBlogCardViewModel(featured)}
        posts={rest.map(toBlogCardViewModel)}
        client:visible
      />
    ) : (
      <div class="border-b px-8 py-16 text-center">
        <p class="font-mono text-[11px] tracking-widest text-muted-foreground uppercase">
          No posts published yet
        </p>
      </div>
    )}
  </PageShell>
</Layout>
