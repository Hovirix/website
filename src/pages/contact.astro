---
import ContactForm from "../components/ContactForm.tsx";
import ContactSidebar from "@/components/ContactSidebar.astro";
import PageHeader from "@/components/PageHeader.astro";
import PageShell from "@/components/PageShell.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact">
  <PageShell path="sys://hovirix.dev/contact">
    <span slot="meta" class="font-mono text-[11px] text-muted-foreground">
      Open to work
      <span class="ml-2 inline-block h-1.5 w-1.5 rounded-full bg-primary align-middle" />
    </span>

    <PageHeader title="Let's Talk" />

    <div class="animate-fade-up border-b px-8 pb-10">
      <p class="max-w-sm text-sm leading-[1.9] text-muted-foreground">
        Have a project in mind or just want to say hello?<br />
        I'll get back to you within a day or two.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto]">
      <div class="animate-fade-up delay-200 border-b px-8 py-12 md:border-b-0 md:border-r md:py-16">
        <ContactForm client:visible />
      </div>
      <ContactSidebar />
    </div>
  </PageShell>
</Layout>
