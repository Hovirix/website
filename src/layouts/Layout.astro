---
import "../styles/global.css";
import Footer from "@/components/Footer.astro";
import Navbar from "../components/Navbar.tsx";
import {
	SITE_DESCRIPTION,
	SITE_NAME,
	SITE_TITLE_SUFFIX,
	SITE_URL,
} from "@/lib/site";

interface Props {
	title: string;
	description?: string;
	image?: string;
}

const {
	title,
	description = SITE_DESCRIPTION,
	image = "/og-default.svg",
} = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalUrl = new URL(currentPath, SITE_URL).toString();
const ogImage = new URL(image, SITE_URL).toString();
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content={SITE_NAME} />
    <meta name="robots" content="index, follow" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={`${title} ${SITE_TITLE_SUFFIX}`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} ${SITE_TITLE_SUFFIX}`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{title} {SITE_TITLE_SUFFIX}</title>

    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          if (stored === "light") {
            document.documentElement.classList.remove("dark");
          } else {
            document.documentElement.classList.add("dark");
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="noise scanlines min-h-screen antialiased">

    <!-- Fixed vertical rails -->
    <div class="pointer-events-none fixed inset-0 z-[100]" aria-hidden="true">
      <div class="relative mx-auto h-full max-w-6xl">
        <span class="absolute inset-y-0 left-0 w-px bg-border opacity-50"></span>
        <span class="absolute inset-y-0 right-0 w-px bg-border opacity-50"></span>
      </div>
    </div>

    <Navbar currentPath={currentPath} client:idle />

    <main>
      <slot />
    </main>

    <Footer />

  </body>
</html>
