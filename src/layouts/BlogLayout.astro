---
import Layout from "./Layout.astro";
import BlogPostSidebar from "@/components/BlogPostSidebar.astro";

interface Props {
	title: string;
	description: string;
	category: string;
	dateFormatted: string;
	image: {
		src: string;
		alt: string;
	};
}

const { title, description, category, dateFormatted, image } = Astro.props;
---

<Layout title={title} description={description} image={image.src}>
  <div class="mx-auto max-w-6xl">
    <div class="animate-fade-in flex items-center justify-between border-b px-8 py-3">
      <div class="flex items-center gap-2 font-mono text-[11px] text-muted-foreground">
        <a href="/blog" class="uppercase tracking-[0.22em] transition-colors hover:text-foreground">
          Blog
        </a>
        <span class="text-border">/</span>
        <span class="text-primary uppercase tracking-wider">{category}</span>
      </div>
      <span class="font-mono text-[11px] text-muted-foreground">{dateFormatted}</span>
    </div>

    <div class="animate-fade-up border-b px-8 py-14">
      <h1 class="mb-5 max-w-3xl text-[clamp(2.2rem,6vw,4.5rem)] font-extrabold leading-[0.95] tracking-[-0.04em] text-foreground">
        {title}
      </h1>
      <p class="max-w-2xl text-base leading-relaxed text-muted-foreground">
        {description}
      </p>
    </div>

    <div class="animate-fade-in delay-200 border-b">
      <div class="relative overflow-hidden">
        <img
          src={image.src}
          alt={image.alt}
          class="aspect-[16/6] w-full object-cover"
        />
        <span class="absolute bottom-0 left-0 h-[3px] w-full bg-primary" />
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto]">
      <article class="animate-fade-up delay-300 border-r-0 px-8 py-12 md:border-r md:py-16">
        <div class="prose">
          <slot />
        </div>
      </article>

      <BlogPostSidebar title={title} category={category} dateFormatted={dateFormatted} />
    </div>
  </div>
</Layout>
